# Copy this file to init-project.env in a copied HarnessWeaver project, fill it in,
# then run: bash scripts/init-project.sh --config init-project.env
#
# Values below are examples, not a recommended product direction. Replace them
# with the target project's real identity, MVP loop, guardrails, and open questions.

HW_PROJECT_NAME="My Project"
HW_DOMAIN="local productivity tool"
HW_PRIMARY_USER="solo operators"
HW_MVP_FOCUS="capture and review daily notes"
HW_NON_GOALS="building a multi-user platform, adding billing, or deploying production infrastructure"

HW_PROJECT_SUMMARY="a local productivity tool for capturing and reviewing daily notes"
HW_PRIMARY_USER_PROBLEM="Solo operators need a low-friction way to capture daily notes and review what needs follow-up."
HW_PRODUCT_PROMISE="The project helps users capture daily notes, review open loops, and decide the next action without adding platform overhead."

HW_SUCCESS_CRITERION_1="A user can complete the primary MVP loop locally."
HW_SUCCESS_CRITERION_2="Project-specific guardrails are documented before implementation."
HW_SUCCESS_CRITERION_3="Strict instance verification passes before task execution starts."

HW_IN_SCOPE_1="A narrow local-first MVP loop."
HW_IN_SCOPE_2="Project-specific PRD and domain guardrails."
HW_IN_SCOPE_3="Verification through the HarnessWeaver scripts."
HW_OUT_OF_SCOPE_1="Authentication or billing."
HW_OUT_OF_SCOPE_2="Production deployment."
HW_OUT_OF_SCOPE_3="Broad platform abstractions."

HW_MVP_LOOP_STEP_1="Define project identity and MVP boundary"
HW_MVP_LOOP_STEP_2="Create a small task with acceptance criteria"
HW_MVP_LOOP_STEP_3="Implement the smallest complete slice"
HW_MVP_LOOP_STEP_4="Run verification and hand off for review"

HW_PRIMARY_FLOW_STEP_1="User opens the local project"
HW_PRIMARY_FLOW_STEP_2="User completes the primary MVP action"
HW_PRIMARY_FLOW_STEP_3="User receives useful feedback"
HW_PRIMARY_FLOW_STEP_4="User can review completion or next steps"
HW_EDGE_FLOW_1="Required project context is missing"
HW_EDGE_FLOW_2="Verification fails and reports actionable output"
HW_EDGE_FLOW_3="A requested change expands scope and becomes a new task"

HW_CORE_LOOP_STEP_1="Start from the project-specific MVP boundary"
HW_CORE_LOOP_STEP_2="Execute one small task"
HW_CORE_LOOP_STEP_3="Verify the result"
HW_CORE_LOOP_STEP_4="Prepare a human handoff"
HW_FEATURE_PRINCIPLE_1="Prefer project-specific clarity over generic platform features."
HW_FEATURE_PRINCIPLE_2="Keep setup and verification repeatable."
HW_FEATURE_PRINCIPLE_3="Record open questions instead of hiding uncertainty."

HW_FIELD_1="status"
HW_FIELD_2="owner"
HW_FIELD_3="reviewStatus"

HW_PRODUCT_QUESTION_1="What is the narrowest valuable MVP loop?"
HW_PRODUCT_QUESTION_2="Which user-facing states must be represented first?"
HW_PRODUCT_QUESTION_3="Which product behaviors are explicitly out of scope?"
HW_TECHNICAL_QUESTION_1="Which checks can run before product code exists?"
HW_TECHNICAL_QUESTION_2="When should fixture validation be introduced?"
HW_TECHNICAL_QUESTION_3="What tooling is stable enough for CI?"

HW_GENERIC_FAILURE_MODE="a generic app"
HW_PRIMARY_USER_GOAL="complete the primary MVP loop with clear feedback"
HW_CONTENT_REVIEW_STATUS_RULE="explicit placeholder, needs_review, or reviewed status"
HW_FEEDBACK_REASONING_RULE="why the result matters and what the user should do next"
